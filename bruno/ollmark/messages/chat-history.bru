{
  "name": "Get chat history",
  "request": {
    "method": "GET",
    "url": "{{BASE_URL}}/api/ai/chat/{{PROJECT_ID}}/history?limit=10"
  },
  "tests": [
    {
      "name": "History returns 200",
      "script": "pm.test('Status is 200', function() { pm.response.to.have.status(200); });\npm.test('Returns an array', function() { var json = pm.response.json(); pm.expect(Array.isArray(json)).to.eql(true); });"
    }
  ]
}