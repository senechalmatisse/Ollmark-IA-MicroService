{
  "name": "Get AI prompt",
  "request": {
    "method": "GET",
    "url": "{{BASE_URL}}/api/ai/config/prompt?projectId={{PROJECT_ID}}"
  },
  "tests": [
    {
      "name": "Prompt returns 200",
      "script": "pm.test('Status is 200', function() { pm.response.to.have.status(200); });\npm.test('Prompt exists', function() { var json = pm.response.json(); pm.expect(json.prompt).to.exist; });"
    }
  ]
}