meta {
  name: "Get AI prompt"
  type: "http"
}

get {
  url: {{BASE_URL}}/api/ai/config/prompt?projectId={{PROJECT_ID}}
}

tests {
  pm.test("Status is 200", function() {
    pm.response.to.have.status(200);
  });
  pm.test("Prompt exists", function() {
    var json = pm.response.json();
    pm.expect(json.prompt).to.exist;
  });
}