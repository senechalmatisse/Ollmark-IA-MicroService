meta {
  name: "Update AI prompt"
  type: "http"
}

post {
  url: {{BASE_URL}}/api/ai/config/prompt?projectId={{PROJECT_ID}}
}

headers {
  Content-Type: "application/json"
}

body:json {
  "prompt": "You are a friendly AI"
}

tests {
  pm.test("Status is 200", function() {
    pm.response.to.have.status(200);
  });
  pm.test("Prompt updated", function() {
    var json = pm.response.json();
    pm.expect(json.success).to.eql(true);
    pm.expect(json.prompt).to.eql("You are a friendly AI");
  });
}