{
  "name": "Update AI prompt",
  "request": {
    "method": "POST",
    "url": "{{BASE_URL}}/api/ai/config/prompt?projectId={{PROJECT_ID}}",
    "body": {
      "prompt": "You are a friendly AI"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "tests": [
    {
      "name": "Update prompt returns success",
      "script": "pm.test('Status is 200', function() { pm.response.to.have.status(200); });\npm.test('Prompt updated', function() { var json = pm.response.json(); pm.expect(json.success).to.eql(true); pm.expect(json.prompt).to.eql('You are a friendly AI'); });"
    }
  ]
}