{
  "name": "Chat AI",
  "request": {
    "method": "POST",
    "url": "{{BASE_URL}}/api/ai/chat",
    "body": {
      "projectId": "{{PROJECT_ID}}",
      "message": "Hello AI",
      "sessionId": "session-1"
    },
    "headers": {
      "Content-Type": "application/json"
    }
  },
  "tests": [
    {
      "name": "Chat returns 200 and response",
      "script": "pm.test('Status is 200', function() { pm.response.to.have.status(200); });\npm.test('Success is true', function() { var json = pm.response.json(); pm.expect(json.success).to.eql(true); });"
    }
  ]
}