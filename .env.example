# ═══════════════════════════════════════════════════════════════════
#  penpot-ai-server — Variables d'environnement
#  Copiez ce fichier en .env et renseignez les valeurs manquantes.
#  Ne committez JAMAIS le fichier .env (ajoutez-le à .gitignore).
# ═══════════════════════════════════════════════════════════════════

# ── Profil Spring actif ────────────────────────────────────────────
# Valeurs possibles : local | dev | preprod | prod
SPRING_PROFILES_ACTIVE=local

# ═══════════════════════════════════════════════════════════════════
#  BASE DE DONNÉES PostgreSQL
# ═══════════════════════════════════════════════════════════════════

# URL JDBC complète (utilisée par les profils dev / preprod / prod)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/penpot_ai

SPRING_DATASOURCE_USERNAME=penpot_ai
SPRING_DATASOURCE_PASSWORD=changeme

# Variables granulaires utilisées par le profil "local" uniquement
# (le profil local reconstruit l'URL à partir de ces variables)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=penpot_ai
DB_USER=penpot_ai
DB_PASSWORD=changeme

# ═══════════════════════════════════════════════════════════════════
#  OLLAMA — LLM & EMBEDDINGS
# ═══════════════════════════════════════════════════════════════════

# URL de base du serveur Ollama (avec slash final)
OLLAMA_BASE_URL=http://localhost:11434/

# ── Modèle exécuteur (génération de design, appels tools) ──────────
PENPOT_EXECUTOR_MODEL=qwen3.5:9b
PENPOT_EXECUTOR_TEMPERATURE=0.7
PENPOT_EXECUTOR_TOP_P=0.95
PENPOT_EXECUTOR_TOP_K=20
PENPOT_EXECUTOR_REPEAT_PENALTY=1.15
PENPOT_EXECUTOR_PRESENCE_PENALTY=0.3
PENPOT_EXECUTOR_MAX_TOKENS=4096
PENPOT_EXECUTOR_NUM_CTX=32000

# ── Modèle routeur d'intention (classification, température 0.0) ───
PENPOT_ROUTER_MODEL=llama3.1
PENPOT_ROUTER_TEMPERATURE=0.0
PENPOT_ROUTER_TOP_P=0.9
PENPOT_ROUTER_TOP_K=10
PENPOT_ROUTER_REPEAT_PENALTY=1.05
PENPOT_ROUTER_MAX_TOKENS=256
PENPOT_ROUTER_NUM_CTX=8192

# ── Modèle d'embedding (RAG / recherche sémantique) ───────────────
OLLAMA_EMBEDDING_MODEL=hf.co/unsloth/embeddinggemma-300m-GGUF:Q8_0

# ═══════════════════════════════════════════════════════════════════
#  PENPOT — WEBSOCKET PLUGIN
# ═══════════════════════════════════════════════════════════════════

# Adresse IP ou hostname du serveur Penpot
PENPOT_SERVER_ADDRESS=localhost

# Port WebSocket exposé par le plugin (doit correspondre côté Angular)
PENPOT_WEBSOCKET_PORT=8080

# ═══════════════════════════════════════════════════════════════════
#  RAG — RETRIEVAL-AUGMENTED GENERATION
# ═══════════════════════════════════════════════════════════════════

# Seuil de similarité cosinus (0.0 → tout accepter, 1.0 → exact)
PENPOT_RAG_SIMILARITY_THRESHOLD=0.5

# Nombre maximum de templates retournés par recherche
PENPOT_RAG_TOP_K=3

# Nombre de variantes de requête générées par MultiQueryExpander
PENPOT_RAG_QUERY_VARIANTS=2

# true = templates vectorisés au démarrage (recommandé en prod)
# false = chargement métadonnées uniquement, sans appel embedding
PENPOT_RAG_EAGER_EMBEDDING=true

# ═══════════════════════════════════════════════════════════════════
#  MÉMOIRE CONVERSATIONNELLE
# ═══════════════════════════════════════════════════════════════════

# Nombre maximum de messages conservés dans la fenêtre de mémoire
PENPOT_CHAT_MEMORY_MAX_MESSAGES=50

# ═══════════════════════════════════════════════════════════════════
#  SÉCURITÉ & CHIFFREMENT
# ═══════════════════════════════════════════════════════════════════

# Clé maître Jasypt pour le chiffrement des secrets en base de données
# Générer avec : openssl rand -hex 32
CRYPTO_MASTER_KEY=CHANGEME_32_HEX_CHARS_MINIMUM

# ── Swagger UI ────────────────────────────────────────────────────
# Utilisateur Swagger (défaut : admin_audit)
SWAGGER_USER=admin_audit

# Mot de passe Swagger UI (obligatoire)
SWAGGER_PASSWORD=changeme

# Activer / désactiver Swagger (true en dev, false en prod recommandé)
SWAGGER_ENABLED=true

# ═══════════════════════════════════════════════════════════════════
#  LOGS
# ═══════════════════════════════════════════════════════════════════

# Répertoire de sortie des fichiers de log
PENPOT_LOG_DIR=logs

# Activer la journalisation des prompts envoyés au LLM (debug uniquement)
SPRING_AI_LOG_PROMPT=false